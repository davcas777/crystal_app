# Copie este archivo a .env (solo para desarrollo local) — NO subir valores reales al repo.
# Dentro de Databricks Apps estas variables se configuran en app.yaml.

# Personal access token, únicamente para desarrollo local
DATABRICKS_TOKEN=dapi-xxxxxxxxxxxxxxxxxxxxxxxxxx

# URL base del AI Gateway (debe terminar en /ai-gateway/mlflow/v1)
AI_GATEWAY_BASE_URL=https://<su-workspace>.azuredatabricks.net/ai-gateway/mlflow/v1

# Endpoints (formato corto o arreglo JSON)
AI_GATEWAY_ENDPOINTS=gpt,claude

# Configuración opcional
AI_GATEWAY_MAX_TOKENS=1024
CHAT_HISTORY_DB_PATH=/tmp/crystal_chat_history.db

# Identidad simulada para pruebas locales (en producción la trae Databricks Apps por header)
LOCAL_USER_EMAIL=usuario@crystal.com.co
