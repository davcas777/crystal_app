# Copy to .env (for local dev) — do NOT commit real values.
# Inside Databricks Apps these are set via app.yaml.

# Personal access token used only for local development
DATABRICKS_TOKEN=dapi-xxxxxxxxxxxxxxxxxxxxxxxxxx

# AI Gateway base URL (must end at /ai-gateway/mlflow/v1)
AI_GATEWAY_BASE_URL=https://<your-workspace>.azuredatabricks.net/ai-gateway/mlflow/v1

# Endpoints (short form or JSON array)
AI_GATEWAY_ENDPOINTS=gpt,claude

# Optional overrides
AI_GATEWAY_MAX_TOKENS=1024
CHAT_HISTORY_DB_PATH=/tmp/crystal_chat_history.db

# Pretend identity for local testing (real users come from Databricks Apps headers)
LOCAL_USER_EMAIL=you@crystal.com.co
